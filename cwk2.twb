      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='Arial Black' fontsize='10'>Car Ownership vs Employment</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Data11' name='federated.0thi0nr1oqsrg512lb0ch02g9zf4' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Value Type' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Absolute&quot;'>
              <calculation class='tableau' formula='&quot;Absolute&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0thi0nr1oqsrg512lb0ch02g9zf4'>
            <column datatype='integer' name='[(2, 3, 4) Car or Van]' role='measure' type='quantitative' />
            <column datatype='integer' name='[1 Car or Van]' role='measure' type='quantitative' />
            <column datatype='integer' name='[10 km &lt; Distance &lt; 30 km]' role='measure' type='quantitative' />
            <column datatype='integer' name='[30 km &lt; Distanc &lt; 60 km]' role='measure' type='quantitative' />
            <column caption='x_Employed' datatype='real' name='[Calculation_0845310044160000]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Absolute&quot; THEN [Economically active]&#13;&#10;ELSE &#13;&#10;FLOAT([Economically active])/FLOAT([Economically active]+ [Economically Inactive]+ [Unemployed])&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Y_car' datatype='real' name='[Calculation_0845310045065217]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='If [Parameters].[Parameter 1] = &quot;Absolute&quot; THEN [1 Car or Van]&#13;&#10;ELSE [1 Car or Van]/([No Cars and Vans]+ [1 Car or Van] + [(2, 3, 4) Car or Van])&#13;&#10;END' />
            </column>
            <column caption='Distance' datatype='real' name='[Calculation_0845310045573122]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Absolute&quot; THEN &#13;&#10;    [Distance &lt; 10 km] &#13;&#10;ELSE &#13;&#10;    [Distance &lt; 10 km] / ([Distance &lt; 10 km]+ [10 km &lt; Distance &lt; 30 km] + [30 km &lt; Distanc &lt; 60 km])&#13;&#10; &#13;&#10;END' />
            </column>
            <column caption='Unit Person' datatype='string' name='[Calculation_0845310217703430]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Absolute&quot; THEN &quot;Persons&quot; ELSE &quot;%&quot; END' />
            </column>
            <column caption='Unit Household' datatype='string' name='[Calculation_0845310217883655]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Absolute&quot; THEN &quot;Households&quot; ELSE &quot;%&quot; END' />
            </column>
            <column caption='Tooltip Employed' datatype='real' name='[Calculation_0845310218031112]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Proportion&quot; THEN [Calculation_0845310044160000]*100 ELSE [Calculation_0845310044160000] END' />
            </column>
            <column caption='Tooltip Car' datatype='real' name='[Calculation_0845310218448906]' role='measure' type='quantitative'>
