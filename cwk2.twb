        <calculation class='tableau' formula='IF [Pivot Field Names] = &quot;2+ Cars&quot;&#13;&#10; OR [Pivot Field Names] = &quot;1 Car&quot;&#13;&#10; OR [Pivot Field Names] = &quot;No Car&quot;&#13;&#10;THEN &quot;Car Ownership (Household)&quot;&#13;&#10;&#13;&#10;ELSEIF [Pivot Field Names] = &quot;Youth (0-19)&quot;&#13;&#10; OR [Pivot Field Names] = &quot;Working (20-64)&quot;&#13;&#10; OR [Pivot Field Names] = &quot;Retired (65-90)&quot;&#13;&#10;THEN &quot;Age Distribution (Person)&quot;&#13;&#10;&#13;&#10;ELSEIF [Pivot Field Names] = &quot;&lt; 10 km&quot;&#13;&#10; OR [Pivot Field Names] = &quot;10-30 km&quot;&#13;&#10; OR [Pivot Field Names] = &quot;30-60 km&quot;&#13;&#10;THEN &quot;Commute Distance (Person)&quot;&#13;&#10;&#13;&#10;ELSEIF [Pivot Field Names] = &quot;Employed&quot;&#13;&#10; OR [Pivot Field Names] = &quot;Inactive&quot;&#13;&#10; OR [Pivot Field Names] = &quot;Unemployed&quot;&#13;&#10;THEN &quot;Employment Status (Person)&quot;&#13;&#10;&#13;&#10;END' />
