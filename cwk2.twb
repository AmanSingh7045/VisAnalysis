          <datasource-dependencies datasource='federated.0thi0nr1oqsrg512lb0ch02g9zf4 (copy)'>
            <column caption='Category' datatype='string' name='[Calculation_2112492622295042]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Pivot Field Names] = &quot;2+ Cars&quot;&#13;&#10; OR [Pivot Field Names] = &quot;1 Car&quot;&#13;&#10; OR [Pivot Field Names] = &quot;No Car&quot;&#13;&#10;THEN &quot;Car Ownership (Household)&quot;&#13;&#10;&#13;&#10;ELSEIF [Pivot Field Names] = &quot;Youth (0-19)&quot;&#13;&#10; OR [Pivot Field Names] = &quot;Working (20-64)&quot;&#13;&#10; OR [Pivot Field Names] = &quot;Retired (65-90)&quot;&#13;&#10;THEN &quot;Age Distribution (Person)&quot;&#13;&#10;&#13;&#10;ELSEIF [Pivot Field Names] = &quot;&lt; 10 km&quot;&#13;&#10; OR [Pivot Field Names] = &quot;10-30 km&quot;&#13;&#10; OR [Pivot Field Names] = &quot;30-60 km&quot;&#13;&#10;THEN &quot;Commute Distance (Person)&quot;&#13;&#10;&#13;&#10;ELSEIF [Pivot Field Names] = &quot;Employed&quot;&#13;&#10; OR [Pivot Field Names] = &quot;Inactive&quot;&#13;&#10; OR [Pivot Field Names] = &quot;Unemployed&quot;&#13;&#10;THEN &quot;Employment Status (Person)&quot;&#13;&#10;&#13;&#10;END' />
              <aliases>
                <alias key='&quot;Age Distribution (Person)&quot;' value='Age Profile (Person)' />
                <alias key='&quot;Car Ownership (Household)&quot;' value='Car Access (Household)' />
                <alias key='&quot;Commute Distance (Person)&quot;' value='Travel Dist. (Person)' />
                <alias key='&quot;Employment Status (Person)&quot;' value='Job Status (Person)' />
              </aliases>
            </column>
            <column caption='Filter County' datatype='boolean' name='[Calculation_2112493170503694]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[geography] = [Parameters].[Geography_Pivot Parameter]' />
            </column>
            <column caption='Cluster Name' datatype='string' name='[Calculation_2112493181812752]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [cluster]&#13;&#10;WHEN 0 THEN &quot;Suburban&quot;&#13;&#10;WHEN 1 THEN &quot;Commuters&quot;&#13;&#10;WHEN 2 THEN &quot;Mixed&quot;&#13;&#10;WHEN 3 THEN &quot;Urban&quot;&#13;&#10;END' />
            </column>
            <column caption='Category - Split 3' datatype='string' name='[Calculation_2112493207822355]' role='dimension' type='nominal' user:unnamed='Sheet 3'>
              <calculation class='tableau' formula='//Category - Split 3&#10;TRIM( SPLIT( [Calculation_2112492622295042], &quot;(&quot;, 1 ) )' />
              <aliases>
                <alias key='&quot;Age Distribution&quot;' value='Age Profile' />
                <alias key='&quot;Car Ownership&quot;' value='Car Access' />
                <alias key='&quot;Commute Distance&quot;' value='Travel Dist.' />
                <alias key='&quot;Employment Status&quot;' value='Job Status' />
              </aliases>
            </column>
            <column caption='Category - Split 4' datatype='string' name='[Calculation_2112493207822356]' role='dimension' type='nominal' user:unnamed='Sheet 3'>
              <calculation class='tableau' formula='//Category - Split 4&#10;TRIM( SPLIT( SPLIT( [Calculation_2112492622295042], &quot;(&quot;, 2 ), &quot;)&quot;, 1 ) )' />
              <aliases>
                <alias key='&quot;Household&quot;' value='(Household)' />
                <alias key='&quot;Person&quot;' value='(Person)' />
              </aliases>
            </column>
            <column caption='Display Value' datatype='real' name='[Calculation_2112493298151445]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Absolute&quot; THEN &#13;&#10;    SUM([Pivot Field Values])&#13;&#10;ELSE &#13;&#10;    [Calculation_2112493314531353]&#13;&#10;END' />
            </column>
            <column caption='Total Category Field' datatype='integer' name='[Calculation_2112493314015256]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [Calculation_2112492622295042], [geography] : SUM([Pivot Field Values])}' />
            </column>
            <column caption='Percentage Value' datatype='real' default-format='p0.00%' name='[Calculation_2112493314531353]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Pivot Field Values])/ SUM([Calculation_2112493314015256])' />
            </column>
            <column caption='Unit' datatype='string' name='[Calculation_2511068049383426]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_2112492622295042] = &quot;Car Ownership (Household)&quot;&#13;&#10;THEN &quot;Households&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_2112492622295042] = &quot;Age Distribution (Person)&quot;&#13;&#10; OR [Calculation_2112492622295042] = &quot;Commute Distance (Person)&quot;&#13;&#10;OR [Calculation_2112492622295042] = &quot;Employment Status (Person)&quot;&#13;&#10; &#13;&#10;THEN &quot;Persons&quot;&#13;&#10;&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Calculation1' datatype='string' name='[Calculation_2511068053753861]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF ATTR([Parameters].[Parameter 1]) = &quot;Absolute&quot; THEN &#13;&#10;    REGEXP_REPLACE(STR(ROUND([Calculation_2112493298151445],0)),&quot;(\d)(?=(\d{3})+$)&quot;, &quot;$1,&quot;) + &quot; &quot; + STR(ATTR([Calculation_2511068049383426]))&#13;&#10;ELSE &#13;&#10;    STR(ROUND([Calculation_2112493298151445] * 100, 1)) + &quot;%&quot;&#13;&#10;END' />
            </column>
