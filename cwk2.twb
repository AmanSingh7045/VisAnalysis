      <aliases enabled='yes' />
      <column caption='Cluster Name21-11' datatype='string' name='[Calculation_0662513302777862]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [cluster]&#13;&#10;WHEN 0 THEN &quot;Suburban&quot;&#13;&#10;WHEN 1 THEN &quot;Commuters&quot;&#13;&#10;WHEN 2 THEN &quot;Mixed&quot;&#13;&#10;WHEN 3 THEN &quot;Urban&quot;&#13;&#10;END' />
      </column>
      <column caption='Total Population per cluster' datatype='integer' name='[Calculation_0662513308577799]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [Calculation_0662513302777862], [Pivot Field Names - Split 2]: SUM([Pivot Field Values])}' />
      </column>
      <column caption='Proportion Value' datatype='real' default-format='p0.00%' name='[Calculation_0662513309093896]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Pivot Field Values])/SUM([Calculation_0662513308577799])' />
      </column>
      <column caption='Dynamic Dumbell' datatype='real' name='[Calculation_0662513309462537]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Absolute&quot;&#13;&#10;THEN SUM([Pivot Field Values])&#13;&#10;ELSE [Calculation_0662513309093896]&#13;&#10;END' />
      </column>
      <column caption='Calculation1' datatype='string' name='[Calculation_2511068226129929]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ATTR([Parameters].[Parameter 1]) = &quot;Absolute&quot; THEN &#13;&#10;    REGEXP_REPLACE(STR(ROUND([Calculation_0662513309462537],0)),&quot;(\d)(?=(\d{3})+$)&quot;, &quot;$1,&quot;) + &quot; &quot; + &quot;Persons&quot;&#13;&#10;ELSE &#13;&#10;    STR(ROUND([Calculation_0662513309462537] * 100, 1)) + &quot;%&quot;&#13;&#10;END' />
      </column>
      <column caption='Age Category' datatype='string' name='[Pivot Field Names - Split 1]' role='dimension' type='nominal' user:SplitFieldIndex='1' user:SplitFieldOrigin='[federated.0h7ur751upo8g615ls4z619gee9r].[Pivot Field Names]'>
        <calculation class='tableau' formula='TRIM( SPLIT( [Pivot Field Names], &quot; &quot;, 1 ) )' />
        <aliases>
          <alias key='&quot;Retired&quot;' value='Retired (65+)' />
          <alias key='&quot;Working&quot;' value='Working (20-64)' />
          <alias key='&quot;Youth&quot;' value='Youth (0-19)' />
        </aliases>
      </column>
      <column caption='Year' datatype='string' name='[Pivot Field Names - Split 2]' role='dimension' type='nominal' user:SplitFieldIndex='2' user:SplitFieldOrigin='[federated.0h7ur751upo8g615ls4z619gee9r].[Pivot Field Names]'>
        <calculation class='tableau' formula='TRIM( SPLIT( [Pivot Field Names], &quot; &quot;, 2 ) )' />
      </column>
      <column caption='Category Year' datatype='string' name='[Pivot Field Names]' role='dimension' type='nominal' />
      <column caption='Population' datatype='integer' default-format='n#,##0,K;-#,##0,K' name='[Pivot Field Values]' role='measure' type='quantitative' />
